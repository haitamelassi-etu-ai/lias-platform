LIAS_ENV=development
LIAS_SECRET_KEY=change-this-secret-key-in-production
LIAS_ACCESS_TOKEN_EXPIRE_MINUTES=60
LIAS_PASSWORD_RESET_EXPIRE_MINUTES=30

# Swagger/OpenAPI is enabled in development and disabled by default in production.
LIAS_DOCS_ENABLED=true

# Local convenience only. In production, use Alembic migrations and real data.
LIAS_AUTO_CREATE_TABLES=true
LIAS_AUTO_SEED=true

# PostgreSQL is recommended for the official LIAS deployment.
LIAS_DATABASE_URL=postgresql://lias_user:lias_password@localhost:5432/lias_db
# SQLite is only for local prototypes.
# LIAS_DATABASE_URL=sqlite:///./lias.db

LIAS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LIAS_FRONTEND_URL=http://localhost:5173
LIAS_SEED_PASSWORD=lias2024demo

# ORCID OAuth, required for official ORCID sign-in.
LIAS_ORCID_CLIENT_ID=
LIAS_ORCID_CLIENT_SECRET=
LIAS_ORCID_BASE_URL=https://orcid.org

# Optional SMTP settings for password reset emails.
LIAS_SMTP_HOST=
LIAS_SMTP_PORT=587
LIAS_SMTP_USERNAME=
LIAS_SMTP_PASSWORD=
LIAS_SMTP_FROM_EMAIL=
LIAS_SMTP_USE_TLS=true
