LIAS_ENV=production
LIAS_APP_NAME=LIAS Scientific Platform API

# Generate a strong random value before deployment.
# PowerShell example:
# [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
LIAS_SECRET_KEY=replace-with-a-strong-random-secret
LIAS_ACCESS_TOKEN_EXPIRE_MINUTES=60
LIAS_PASSWORD_RESET_EXPIRE_MINUTES=30

# Keep API documentation private in production.
LIAS_DOCS_ENABLED=false

# Production must use Alembic migrations and real data.
LIAS_AUTO_CREATE_TABLES=false
LIAS_AUTO_SEED=false

# Replace with the production PostgreSQL credentials.
LIAS_DATABASE_URL=postgresql://lias_user:change-this-password@127.0.0.1:5432/lias_db

# Replace with the official frontend URL.
LIAS_CORS_ORIGINS=https://lias.fsbm.ac.ma
LIAS_FRONTEND_URL=https://lias.fsbm.ac.ma

# Demo seed password is not used when LIAS_AUTO_SEED=false.
LIAS_SEED_PASSWORD=replace-or-remove-in-production

# Official ORCID application credentials.
LIAS_ORCID_CLIENT_ID=replace-with-official-orcid-client-id
LIAS_ORCID_CLIENT_SECRET=replace-with-official-orcid-client-secret
LIAS_ORCID_BASE_URL=https://orcid.org

# SMTP is required in production for "forgot password".
LIAS_SMTP_HOST=smtp.example.com
LIAS_SMTP_PORT=587
LIAS_SMTP_USERNAME=notifications@lias.fsbm.ac.ma
LIAS_SMTP_PASSWORD=replace-with-smtp-password
LIAS_SMTP_FROM_EMAIL=notifications@lias.fsbm.ac.ma
LIAS_SMTP_USE_TLS=true
